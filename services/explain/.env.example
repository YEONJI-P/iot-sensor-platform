# explain 서비스 설정. 사용:  cp .env.example .env   (.env 는 gitignore)
# 값의 소비처는 app/dependencies.py 의 Settings — 이름은 대소문자 무시로 매칭된다.
# compose 는 이 파일을 env_file 로 읽지만, PORT 는 docker-compose.yml 의 environment 가 덮어쓴다.

# LLM provider 선택: echo | gemini  (기본 echo — 키 없이 동작하는 스텁)
EXPLAIN_PROVIDER=echo

# Gemini 인증 — EXPLAIN_PROVIDER=gemini 일 때만 필요. Google AI Studio에서 발급.
# 키는 환경변수로만 주입한다(이 파일에 실제 값을 쓰지 않는다).
GEMINI_API_KEY=

# 사용 모델 — EXPLAIN_PROVIDER=gemini 일 때만 의미가 있다.
# 코드 기본값은 app/dependencies.py 의 `gemini-2.0-flash` 다. 다만 이 저장소에는 Gemini
# 실호출 검증 근거가 없어(services/explain/README.md "남은 작업" 참조) 어떤 모델명이
# 지금 유효한지 확정할 수 없다. gemini 로 전환할 때 AI Studio에서 확인한 이름을 여기 명시한다.
# MODEL_NAME=gemini-2.0-flash

# 서버 포트. 기본 23200 은 로컬 `uv run uvicorn` 용이다.
# 컨테이너 기본값은 8000(Dockerfile ENV PORT) — 배포·데모 계약과 같다.
PORT=23200

# LLM 호출 타임아웃 초 (기본 30)
REQUEST_TIMEOUT=30

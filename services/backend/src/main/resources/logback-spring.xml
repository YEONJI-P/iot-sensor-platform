<?xml version="1.0" encoding="UTF-8"?>
<!--
  로깅 구성. 콘솔은 항상, 파일은 local 프로파일에서만 남긴다.
  배포/컨테이너는 stdout(콘솔)만 사용한다(12-factor, `docker compose logs`로 수집).
  파일 로그는 로컬 개발 편의용이며 logs/ 아래에 쌓이고 gitignore 처리된다.

  파일 분할:
    app.log      INFO 이상 전체
    error.log    WARN/ERROR만
    pipeline.log 수신·이상판정·AX 연동 흐름만(도메인 로거를 별도 라우팅)
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- local: 콘솔 + 파일 -->
    <springProfile name="local">
        <property name="LOG_DIR" value="logs"/>

        <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/app.log</file>
            <encoder>
                <pattern>${FILE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <encoder>
                <pattern>${FILE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <appender name="PIPELINE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/pipeline.log</file>
            <encoder>
                <pattern>${FILE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/pipeline.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!--
          파이프라인 로거를 PIPELINE_FILE로도 보낸다(additivity 기본 true라
          콘솔·app.log·error.log에도 그대로 전파됨 = pipeline.log는 필터링된 뷰).
        -->
        <!-- 수신 → 저장 → 이상판정 → 실패적재 -->
        <logger name="dev.yeon.iotsensorplatform.sensordata" level="INFO">
            <appender-ref ref="PIPELINE_FILE"/>
        </logger>
        <!-- AX 연동(알림 근거 보강) -->
        <logger name="dev.yeon.iotsensorplatform.alert.scheduler" level="INFO">
            <appender-ref ref="PIPELINE_FILE"/>
        </logger>
        <logger name="dev.yeon.iotsensorplatform.ax" level="INFO">
            <appender-ref ref="PIPELINE_FILE"/>
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="APP_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- 그 외(배포 등): 콘솔(stdout)만 -->
    <springProfile name="!local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>

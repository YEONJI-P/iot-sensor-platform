# 두 Compose 실행 방식에서 사용하는 backend 설정.
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long

# 홈서버에서는 기존 PostgreSQL의 별도 database 접속값으로 교체한다.
# 독립 풀 데모에서는 Compose가 내부 postgres 값으로 덮어쓴다.
DB_URL=jdbc:postgresql://replace-with-postgres-service:5432/sensor_monitor
DB_USERNAME=sensor_monitor
DB_PASSWORD=change-me

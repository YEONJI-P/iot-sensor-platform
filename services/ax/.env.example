# LLM provider 선택: echo | gemini  (기본 echo — 키 없이 동작하는 스텁)
AX_PROVIDER=echo

# Gemini 인증 — AX_PROVIDER=gemini 일 때만 필요. Google AI Studio에서 발급
GEMINI_API_KEY=

# 사용 모델 — 실제 사용 가능한 모델명은 Google AI Studio에서 최신 기준으로 확인
MODEL_NAME=gemini-flash-lite-latest

# 서버 포트 (기본 8000, Spring 23100/데모 8080과 충돌 없음)
PORT=8000

# LLM 호출 타임아웃 초 (기본 30)
REQUEST_TIMEOUT=30

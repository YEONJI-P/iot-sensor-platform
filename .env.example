# 로컬 실행(bootRun): 공용 PostgreSQL 을 저장소 밖에서 직접 실행한다. Spring 은 .env 를
#   자동 로드하지 않으므로 아래 값들은 셸 export 또는 IDE 실행 구성에 넣는다.
# 컨테이너 데모(docker-compose up): compose 가 이 .env 를 자동 로드하고, 자체 postgres 를
#   함께 띄운다. 이 경우 DB_* 는 backend 컨테이너가 내부값을 쓰므로 불필요.

# 두 모드 공통 필수. 기본값이 없어 미설정 시 부팅 실패한다 (최소 32바이트).
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long

# 로컬 실행에서 공용 DB 가 기본 접속정보(localhost:5432/sensor_monitor, 계정 sensor_monitor)와
# 다를 때만 재정의.
# DB_URL=jdbc:postgresql://localhost:5432/sensor_monitor
# DB_USERNAME=sensor_monitor
# DB_PASSWORD=sensor_monitor

# AX(Python) 서비스 연동. 기본은 비활성(application.yml ax.enabled=false).
# docker-compose 가 .env 를 자동 로드해 ax 컨테이너에 주입한다.
# AX_BASE_URL=http://localhost:8000
# AX_ENABLED=false
# AX_PROVIDER=echo
# GEMINI_API_KEY=
# MODEL_NAME=gemini-flash-lite-latest

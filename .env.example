# 홈서버 Compose 전용. 독립 풀 데모에서는 이 파일을 사용하지 않는다.

# backend·explain·simulator 이미지가 공유하는 commit SHA tag.
SENSOR_MONITOR_IMAGE_TAG=replace-with-published-git-sha

# 기존 PostgreSQL 컨테이너가 참가한 외부 Docker network.
SENSOR_MONITOR_DB_NETWORK=replace-with-database-network

# reverse proxy가 참가한 외부 Docker network.
SENSOR_MONITOR_PROXY_NETWORK=replace-with-proxy-network

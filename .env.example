# 루트 .env는 docker-compose.home.yml의 이미지·외부 network 보간에만 사용한다.
# JWT·DB·provider처럼 서비스가 직접 소비하는 설정은 중복하지 않고 각 서비스가 소유한다.
#
#   backend → services/backend/.env.example
#   explain → services/explain/.env.example
#
# 독립 풀 데모(docker-compose.yml)는 루트 .env가 필요 없다.

# GHCR에 수동 발행한 세 이미지가 공유하는 불변 commit SHA tag.
SENSOR_MONITOR_IMAGE_TAG=replace-with-published-git-sha

# 홈서버 기존 PostgreSQL 컨테이너와 backend가 함께 참가하는 외부 Docker network.
SENSOR_MONITOR_DB_NETWORK=replace-with-database-network

# 홈서버 reverse proxy와 backend가 함께 참가하는 외부 Docker network.
SENSOR_MONITOR_PROXY_NETWORK=replace-with-proxy-network

# docker-compose.yml 의 postgresql 컨테이너가 사용 (필수)
# 이 값으로 로컬 DB가 생성되며, application.yml 의 DB_URL 기본값
# (jdbc:postgresql://localhost:5432/iot_sensor_db_v2)과 DB 이름이 일치해야 한다.
POSTGRES_DB=iot_sensor_db_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 애플리케이션(./gradlew bootRun)이 읽는 값.
# Spring 은 .env 를 자동 로드하지 않으므로 셸 export 또는 IDE 실행 구성에 넣는다.
# JWT_SECRET 은 기본값이 없어 미설정 시 부팅 실패한다 (최소 32바이트).
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long

# 아래는 application.yml 에 기본값이 있어 로컬에선 생략 가능. 재정의 시만 설정.
# DB_URL=jdbc:postgresql://localhost:5432/iot_sensor_db_v2
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# REDIS_HOST=localhost
# REDIS_PORT=6379
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
